PORT=3001
HOST=127.0.0.1
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
NEWSAPI_KEY=
# Production-safe default: real data mode unless explicitly set to true.
USE_MOCK_SIGNALS=false
USE_MOCK_FINANCIAL_DATA=false
RADAR_AUTORUN_ENABLED=false
RADAR_AUTORUN_INTERVAL_MINUTES=720
RADAR_AUTORUN_RISK_PROFILE=moderate
RADAR_AUTORUN_UNIVERSE_LIMIT=0
# Optional custom JSON file with NSE universe symbols.
# Expected shape: [{"symbol":"TCS","yahooSymbol":"TCS.NS"}, ...]
NSE_UNIVERSE_FILE=
